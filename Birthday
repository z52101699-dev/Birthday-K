!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Happy Birthday Kanzul Eman</title>

<link href="https://fonts.googleapis.com/css2?family=Pacifico&family=Poppins:wght@300;500&display=swap" rel="stylesheet">

<style>

body{
margin:0;
text-align:center;
font-family:'Poppins',sans-serif;
background: linear-gradient(270deg,#ff9a9e,#fad0c4,#ffc3a0,#ffdde1);
background-size:600% 600%;
animation:bgMove 10s infinite;
color:white;
}

@keyframes bgMove{
0%{background-position:0% 50%;}
50%{background-position:100% 50%;}
100%{background-position:0% 50%;}
}

.container{
margin-top:70px;
background:rgba(0,0,0,0.35);
padding:40px;
border-radius:25px;
display:inline-block;
animation:float 4s infinite;
}

@keyframes float{
0%{transform:translateY(0);}
50%{transform:translateY(-10px);}
100%{transform:translateY(0);}
}

h1{
font-family:'Pacifico',cursive;
font-size:50px;
color:#ffe066;
}

h2{
font-family:'Pacifico',cursive;
}

p{
font-size:20px;
}

button{
padding:12px 25px;
font-size:18px;
border:none;
border-radius:12px;
background:#ff4b5c;
color:white;
cursor:pointer;
}

button:hover{
background:#ff1e3c;
}

#msg{
font-size:22px;
margin-top:20px;
color:#fff9c4;
}

/* Cake Animation */

.cake{
font-size:80px;
animation:cakeMove 2s infinite alternate;
}

@keyframes cakeMove{
from{transform:scale(1);}
to{transform:scale(1.1);}
}

/* Fireworks */

.fireworks{
position:fixed;
top:0;
left:0;
width:100%;
height:100%;
pointer-events:none;
font-size:30px;
animation:fire 1s infinite;
}

@keyframes fire{
0%{opacity:0;}
50%{opacity:1;}
100%{opacity:0;}
}

</style>
</head>

<body>

<audio autoplay loop>
<source src="https://www.soundhelix.com/examples/mp3/SoundHelix-Song-1.mp3" type="audio/mpeg">
</audio>

<div class="fireworks">🎆 ✨ 🎇 ✨ 🎆</div>

<div class="container">

<h1>Happy Birthday 🎉</h1>

<h2>Kanzul Eman 💖</h2>

<div class="cake">🎂</div>

<p>
Dear Kanzul Eman,<br><br>
May your birthday be filled with happiness, smiles and love.  
You are not only my sister but also my best friend.  
May Allah bless you with success, health and a beautiful life.
</p>

<p style="font-size:24px;">Best Wishes From</p>

<h2>❤️ Your Brother Shahroz ❤️</h2>

<button onclick="showMsg()">Click for Surprise 🎁</button>

<p id="msg"></p>

</div>

<script>

function showMsg(){
document.getElementById("msg").innerHTML =
"🎉 Happy Birthday Kanzul Eman! May Allah bless you always. 🎉";
}

</script>

</body>
</html>
